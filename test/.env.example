# Configuration for Region API Tests
#
# For local testing:
#   1. Copy this file: cp test/.env.example test/.env
#   2. Update the values below with your actual configuration
#
# Or use environment-specific files if available:
#   - For dev: cp test/.env.dev test/.env
#   - For UAT: cp test/.env.uat test/.env

# Base URL for the Region API server (via compute gateway)
API_BASE_URL=http://localhost:8080

# Base URL for the Region API server directly (used for image create/delete)
REGION_BASE_URL=http://localhost:8081

# Authentication token for API requests
# This is a service token, which you can create on console, no need to add bearer, it will add it for you
API_AUTH_TOKEN=your-test-token-here

# Test data configuration
# Advised you create all the below in console first and add them all here
TEST_ORG_ID=test-org-12345
TEST_PROJECT_ID=test-project-67890

# You can call the /api/v1/organizations/{{organizationID}}/regions endpoint
TEST_REGION_ID=test-region-abc123
TEST_SECONDARY_PROJECT_ID=test-secondary-project-12345
TEST_SECONDARY_REGION_ID=test-secondary-region-67890

# Optional: pre-existing network ID to use for VAST storage attachment tests.
# If unset, a network will be created and cleaned up automatically.
# Note: SSH and attachment lifecycle tests always create their own network.
TEST_NETWORK_ID=

# Flavor and image IDs for server creation in SSH storage verification tests.
# These are used by the storage_enhanced tests to provision a VM to verify NFS mounts.
# Leave empty to skip SSH-based storage verification tests.
TEST_FLAVOR_ID=
TEST_IMAGE_ID=
# SSH user for the test image (e.g. ubuntu, rocky, ec2-user). Defaults to "ubuntu".
TEST_SSH_USER=ubuntu

# Test timeout settings
REQUEST_TIMEOUT=30s
TEST_TIMEOUT=20m

# Test behavior flags
SKIP_INTEGRATION=false

# Debug settings
DEBUG_LOGGING=false
LOG_REQUESTS=true
LOG_RESPONSES=false
